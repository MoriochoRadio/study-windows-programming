<Window x:Class="_031_wpfgae.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_031_wpfgae"
        mc:Ignorable="d"
        Title="윈도우 표준계산기" Height="600" Width="400" Background="#FFF3F3F3">
    <DockPanel>
        <!--결과창-->
        <Grid Height="100" DockPanel.Dock="Top">
            <TextBox x:Name="txtExp"
                     FontSize="16" HorizontalContentAlignment="Right" 
                     BorderThickness="0"
                     Margin="15" Background="#FFF3F3F3">
                12+34=
            </TextBox>

            <TextBox x:Name="txtResult"
                     Height="45" FontWeight="Bold" FontSize="36" 
                     VerticalAlignment="Bottom" Margin="10 10 15 10"
                     HorizontalContentAlignment="Right"
                     BorderThickness="0"
                     Background="#FFF3F3F3">
                46
            </TextBox>
        </Grid>
        <!--Memory Buttons-->
        <Grid Height="50" DockPanel.Dock="Top" Background="#FFF3F3F3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <Button x:Name="btnMc" Grid.Column="0" FontSize="14" Background="#FFF3F3F3"
                    IsEnabled="False" BorderThickness="0" Click="btnMc_Click">MC
            </Button>
            <Button x:Name="btnMr" Grid.Column="1" FontSize="14" Background="#FFF3F3F3"
                    IsEnabled="False" BorderThickness="0" Click="btnMr_Click">MR
            </Button>
            <Button x:Name="btnMplus" Grid.Column="2" FontSize="14" Background="#FFF3F3F3"
                    IsEnabled="True" BorderThickness="0" Click="btnMplus_Click" >M+
            </Button>
            <Button x:Name="btnMminus" Grid.Column="3" FontSize="14" Background="#FFF3F3F3"
                    IsEnabled="True" BorderThickness="0" Click="btnMminus_Click">M-
            </Button>
            <Button x:Name="btnMs" Grid.Column="4" FontSize="14" Background="#FFF3F3F3"
                    IsEnabled="True" BorderThickness="0" Click="btnMs_Click">MS
            </Button>
        </Grid>
        <!--6행4열버튼-->
        <Grid DockPanel.Dock="Bottom" MinHeight="360" Background="#FFF3F3F3">
            <Grid.RowDefinitions>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
                <RowDefinition/>
            </Grid.RowDefinitions>

            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>

            <!--1행 4개버튼-->
            <Button x:Name="btnPercent" Grid.Row="0" Grid.Column="0" FontSize="18" Margin="2 1 1 1" Background="#FFF9F9F9">%</Button>
            <Button x:Name="btnCe" Grid.Row="0" Grid.Column="1" FontSize="18" Margin="1" Background="#FFF9F9F9" Click="btnCe_Click">CE</Button>
            <Button x:Name="btnC" Grid.Row="0" Grid.Column="2" FontSize="18" Margin="1" Background="#FFF9F9F9" Click="btnC_Click">C</Button>
            <Button x:Name="btnDel" Grid.Row="0" Grid.Column="3" FontSize="18" Margin="1 1 2 1" Background="#FFF9F9F9" Click="btnDel_Click">⌫</Button>

            <!--2행 4개버튼-->
            <Button x:Name="btnRecip" Grid.Row="1" Grid.Column="0" FontSize="18" Margin="2 1 1 1" Background="#FFF9F9F9" Click="btnRecip_Click">1/x</Button>
            <Button x:Name="btnSqr" Grid.Row="1" Grid.Column="1" FontSize="18" Margin="1" Background="#FFF9F9F9" Click="btnSqr_Click">x²</Button>
            <Button x:Name="btnSqrt" Grid.Row="1" Grid.Column="2" FontSize="18" Margin="1" Background="#FFF9F9F9" Click="btnSqrt_Click">√</Button>
            <Button x:Name="btnDivide" Grid.Row="1" Grid.Column="3" FontSize="18" Margin="1 1 2 1" Background="#FFF9F9F9" Click="btnOP_Click">÷</Button>

            <!--3행 4개버튼-->
            <Button x:Name="btn7" Grid.Row="2" Grid.Column="0" FontSize="18" Margin="2 1 1 1" Background="White" Click="btnClick">7</Button>
            <Button x:Name="btn8" Grid.Row="2" Grid.Column="1" FontSize="18" Margin="1" Background="White" Click="btnClick">8</Button>
            <Button x:Name="btn9" Grid.Row="2" Grid.Column="2" FontSize="18" Margin="1" Background="White" Click="btnClick">9</Button>
            <Button x:Name="btnTimes" Grid.Row="2" Grid.Column="3" FontSize="18" Margin="1 1 2 1" Background="#FFF9F9F9" Click="btnOP_Click">×</Button>

            <!--4행 4개버튼-->
            <Button x:Name="btn4" Grid.Row="3" Grid.Column="0" FontSize="18" Margin="2 1 1 1" Background="White" Click="btnClick">4</Button>
            <Button x:Name="btn5" Grid.Row="3" Grid.Column="1" FontSize="18" Margin="1" Background="White" Click="btnClick">5</Button>
            <Button x:Name="btn6" Grid.Row="3" Grid.Column="2" FontSize="18" Margin="1" Background="White" Click="btnClick">6</Button>
            <Button x:Name="btnMinus" Grid.Row="3" Grid.Column="3" FontSize="18" Margin="1 1 2 1" Background="#FFF9F9F9" Click="btnOP_Click">-</Button>

            <!--5행 4개버튼-->
            <Button x:Name="btn1" Grid.Row="4" Grid.Column="0" FontSize="18" Margin="2 1 1 1" Background="White" Click="btnClick">1</Button>
            <Button x:Name="btn2" Grid.Row="4" Grid.Column="1" FontSize="18" Margin="1" Background="White" Click="btnClick">2</Button>
            <Button x:Name="btn3" Grid.Row="4" Grid.Column="2" FontSize="18" Margin="1" Background="White" Click="btnClick">3</Button>
            <Button x:Name="btnPlus" Grid.Row="4" Grid.Column="3" FontSize="18" Margin="1 1 2 1" Background="#FFF9F9F9" Click="btnOP_Click">+</Button>

            <!--6행 4개버튼-->
            <Button x:Name="btnPlusMinus" Grid.Row="5" Grid.Column="0" FontSize="18" Margin="2 1 1 2" Background="White" Click="btnPlusMinus_Click">±</Button>
            <Button x:Name="btn0" Grid.Row="5" Grid.Column="1" FontSize="18" Margin="1 1 1 2" Background="White" Click="btnClick">0</Button>
            <Button x:Name="btnDot" Grid.Row="5" Grid.Column="2" FontSize="18" Margin="1 1 1 2" Background="White" Click="btnDot_Click">.</Button>
            <Button x:Name="btnEqual" Grid.Row="5" Grid.Column="3" FontSize="18" Margin="1 1 2 2" Background="#FF4F88C8" Click="btnEqual_Click">=</Button>
        </Grid>
    </DockPanel>
</Window>

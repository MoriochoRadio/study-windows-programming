<Window x:Class="_028_StckPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:_028_StckPanel"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="400">
    <!-- 제목과 윈도우의 크기를 설정합니다-->
    <StackPanel Orientation="Horizontal">
        <!--컨트롤을 쌓아두는 레이아웃인 StackPanel을 Orientation을 수평으로 설정하여
        버튼들이 모두 수평으로 정렬된다-->
        <Button Padding="10" Margin="10" Content="Btn1">
            <!-- 안쪽 여백인 Padding을 통해 여백을 설정한다-->
        </Button>

        <Button Padding="10" Margin="10" Content="Btn2"> 
 
        </Button>
            
    </StackPanel>
</Window>
